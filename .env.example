# =========================================================================
# Variables de entorno OPCIONALES para ajustar puertos del docker-compose
# =========================================================================
#
# COPIA este archivo como .env si necesitas cambiar los puertos por defecto:
#   cp .env.example .env
#
# Luego edita los valores que necesites y corre:
#   docker compose up --build
#
# Si NO copias este archivo, docker-compose usa los puertos por defecto
# (los que estan a la derecha del :- en el docker-compose.yml).
#
# =========================================================================

# Puerto del HOST donde se expone Postgres (default 5432).
# Cambia a 5433 si tienes Postgres local corriendo en 5432.
DB_HOST_PORT=5432

# Puerto del HOST donde se expone el orquestador (default 8080).
ORQUESTADOR_HOST_PORT=8080

# Puerto del HOST donde se expone el MS B (Riesgos Mock) (default 8081).
RIESGOS_HOST_PORT=8081

# Puerto del HOST donde se expone el frontend (Nginx) (default 4200).
FRONTEND_HOST_PORT=4200
